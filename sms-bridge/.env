# SMS Bridge Configuration
PORT=3000
DEFAULT_CHANNEL=general

# ── SMS Transport 1: WiFi Gateway (SMS Gateway for Android app) ──────────────
# Set this to the local IP of the phone running the SMS Gateway app.
# Find it in the app: Menu → API → Local server address
# Example: SMS_GATEWAY_IP=192.168.1.10
SMS_GATEWAY_IP=
SMS_GATEWAY_PORT=8080
SMS_GATEWAY_USER=sms
SMS_GATEWAY_PASS=sms

# ── SMS Transport 2: ADB over USB ────────────────────────────────────────────
# Reads/sends SMS via USB-connected Android phone using ADB.
# No extra app needed — just enable USB Debugging on the phone.
#
# SETUP:
#   1. Phone: Settings → Developer Options → USB Debugging → ON
#   2. Connect phone to PC via USB cable
#   3. Accept "Allow USB debugging?" on the phone screen
#   4. Download ADB (Android Platform Tools):
#      https://developer.android.com/tools/releases/platform-tools
#   5. Either add adb to your system PATH, or set ADB_PATH below
#
# ADB_PATH = full path to adb.exe if not in system PATH
# Example:  ADB_PATH=C:\platform-tools\adb.exe
ADB_PATH=adb
ADB_ENABLED=true
